---
import { siteConfig } from '@/site.config';
---

<footer class="page-shell pb-10 pt-8">
  <div class="section-card rounded-[2rem] px-6 py-6 text-sm">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="font-semibold">{siteConfig.name}</p>
        <p class="muted">
          Delivered as a static Astro site on GitHub Pages. Based on <a href="https://github.com/bakate/astro-theme-starter" target="_blank" rel="noreferrer">astro-theme-starter</a> by bakate.
        </p>
      </div>
      <div class="flex flex-wrap gap-4">
        <a href={siteConfig.github} target="_blank" rel="noreferrer">GitHub</a>
        <a href={siteConfig.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      </div>
    </div>
    <div class="mt-5 space-y-2 border-t border-[color:var(--line)] pt-4 text-xs">
      <p class="muted">
        Third-party marks are used only for identification of relevant technologies and do
        not imply sponsorship, affiliation, or endorsement.
      </p>
      <p class="muted">
        Unity is a trademark or registered trademark of Unity Technologies or its affiliates
        in the U.S. and elsewhere.
      </p>
      <p class="muted">
        Steam and the Steam logo are trademarks and/or registered trademarks of Valve
        Corporation in the U.S. and/or other countries.
      </p>
    </div>
  </div>
</footer>

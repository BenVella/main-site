---
import { siteConfig } from '@/site.config';
---

<footer class="page-shell pb-10 pt-8">
  <div class="section-card rounded-[2rem] px-6 py-6 text-sm">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="font-semibold">{siteConfig.name}</p>
        <p class="muted">
          Delivered as a static Astro site on GitHub Pages. Based on <a href="https://github.com/bakate/astro-theme-starter" target="_blank" rel="noreferrer">astro-theme-starter</a> by bakate.
        </p>
      </div>
      <div class="flex flex-wrap gap-4">
        <a class="button-secondary gap-2" href={siteConfig.github} target="_blank" rel="noreferrer">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
            <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.02c-3.34.73-4.04-1.61-4.04-1.61a3.18 3.18 0 0 0-1.34-1.75c-1.1-.76.08-.75.08-.75a2.53 2.53 0 0 1 1.85 1.25 2.56 2.56 0 0 0 3.5 1 2.56 2.56 0 0 1 .76-1.6c-2.66-.3-5.47-1.33-5.47-5.91a4.63 4.63 0 0 1 1.23-3.22 4.3 4.3 0 0 1 .12-3.18s1-.32 3.3 1.23a11.35 11.35 0 0 1 6 0c2.3-1.55 3.29-1.23 3.29-1.23a4.3 4.3 0 0 1 .12 3.18 4.62 4.62 0 0 1 1.23 3.22c0 4.59-2.81 5.6-5.49 5.9a2.86 2.86 0 0 1 .82 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 .5Z"/>
          </svg>
          GitHub
        </a>
        <a class="button-secondary gap-2" href={siteConfig.linkedin} target="_blank" rel="noreferrer">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
            <path d="M4.98 3.5C4.98 4.88 3.87 6 2.49 6S0 4.88 0 3.5 1.11 1 2.49 1s2.49 1.12 2.49 2.5ZM.5 8h4V23h-4V8Zm7 0h3.83v2.05h.06c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.77 2.65 4.77 6.1V23h-4v-7.76c0-1.85-.03-4.24-2.58-4.24-2.58 0-2.97 2.02-2.97 4.11V23h-4V8Z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
    <div class="mt-5 space-y-2 border-t border-[color:var(--line)] pt-4 text-xs">
      <p class="muted">
        Third-party marks are used only for identification of relevant technologies and do
        not imply sponsorship, affiliation, or endorsement.
      </p>
      <p class="muted">
        Unity is a trademark or registered trademark of Unity Technologies or its affiliates
        in the U.S. and elsewhere.
      </p>
      <p class="muted">
        Steam and the Steam logo are trademarks and/or registered trademarks of Valve
        Corporation in the U.S. and/or other countries.
      </p>
      <p class="muted">Java is a trademark or registered trademark of Oracle and/or its affiliates.</p>
      <p class="muted">
        MuleSoft is a trademark of Salesforce, Inc. and is used here only to identify
        platform experience.
      </p>
    </div>
  </div>
</footer>

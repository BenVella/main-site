---
import type { Project } from '@/features/projects/service';

type Props = {
  project: Project;
};

const { project } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<article class="section-card flex h-full flex-col rounded-[1.75rem] p-6">
  <p class="eyebrow mb-4">{project.category}</p>
  <h3 class="display-face text-2xl font-semibold">{project.title}</h3>
  <p class="mt-2 text-sm muted">{project.period}</p>
  <p class="mt-4 flex-1 leading-7 muted">{project.summary}</p>
  <div class="mt-6 flex flex-wrap gap-2">
    {
      project.tags.map((tag) => (
        <span class="chip">
          {tag}
        </span>
      ))
    }
  </div>
  <a
    href={`${baseUrl}projects/${project.slug}`}
    class="mt-6 inline-flex items-center text-sm font-semibold"
    style="color: var(--accent);"
  >
    View case study
  </a>
</article>

---
import type { Project } from '@/features/projects/service';

type Props = {
  project: Project;
};

const { project } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<article class="section-card overflow-hidden rounded-[1.75rem] p-4">
  <img
    src={`${baseUrl}${project.image.src}`}
    alt={project.image.alt}
    loading="lazy"
    class="h-52 w-full rounded-2xl object-cover"
  />
  <div class="px-1 pb-2 pt-4">
    <p class="text-xs font-semibold uppercase tracking-[0.16em] muted">{project.company}</p>
    <h3 class="mt-2 display-face text-2xl font-semibold">{project.title}</h3>
    <p class="mt-2 text-sm muted">{project.role} · {project.period}</p>
    <p class="mt-4 leading-7 muted">{project.caption}</p>
    <a
      href={`${baseUrl}projects/${project.slug}`}
      class="mt-5 inline-flex items-center text-sm font-semibold"
      style="color: var(--accent);"
    >
      Open project details
    </a>
  </div>
</article>

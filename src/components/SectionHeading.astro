---
type Props = {
  eyebrow?: string;
  title: string;
  intro?: string;
};

const { eyebrow, title, intro } = Astro.props;
---

<div class="mb-8 max-w-3xl">
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <h2 class="display-face text-3xl font-semibold tracking-tight md:text-4xl">
    {title}
  </h2>
  {intro && <p class="mt-4 text-base leading-7 muted md:text-lg">{intro}</p>}
</div>

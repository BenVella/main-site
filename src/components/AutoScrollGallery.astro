---
import type { GalleryImage } from '@/types/gallery';
import { withBase } from '@/utils/base-path';

type Props = {
  items: GalleryImage[];
  galleryId?: string;
  imageClass?: string;
};

const { items, galleryId, imageClass = '' } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const resolvedImageClass = ['auto-scroll-gallery-image', imageClass].filter(Boolean).join(' ');
---

<div class="auto-scroll-gallery" data-auto-scroll-gallery id={galleryId}>
  <div class="auto-scroll-gallery-track" data-auto-scroll-gallery-track>
    {
      items.map((item, index) => (
        <figure
          class="auto-scroll-gallery-slide"
          data-auto-scroll-gallery-slide
          aria-label={`Gallery image ${index + 1} of ${items.length}`}
        >
          <img
            src={withBase(baseUrl, item.src)}
            alt={item.alt}
            loading="lazy"
            class={resolvedImageClass}
          />
          <figcaption class="auto-scroll-gallery-caption">{item.caption ?? item.alt}</figcaption>
        </figure>
      ))
    }
  </div>
</div>

<script>
  const startAutoScrollGallery = (galleryRoot: Element) => {
    if (!(galleryRoot instanceof HTMLElement)) return null;
    if (galleryRoot.dataset.autoScrollGalleryReady === 'true') return null;
    galleryRoot.dataset.autoScrollGalleryReady = 'true';

    const track = galleryRoot.querySelector('[data-auto-scroll-gallery-track]');
    const slides = Array.from(galleryRoot.querySelectorAll('[data-auto-scroll-gallery-slide]'));
    if (!(track instanceof HTMLElement) || slides.length <= 1) return null;

    let activeIndex = 0;
    let intervalId: number | null = null;
    let scrollTimer: number | null = null;

    const goToSlide = (index: number) => {
      activeIndex = index;
      const targetSlide = slides[activeIndex];
      if (!(targetSlide instanceof HTMLElement)) return;
      track.scrollTo({ left: targetSlide.offsetLeft, behavior: 'smooth' });
    };

    const syncIndexFromScroll = () => {
      const currentLeft = track.scrollLeft;
      let nearestIndex = 0;
      let nearestDistance = Number.POSITIVE_INFINITY;

      slides.forEach((slide, index) => {
        if (!(slide instanceof HTMLElement)) return;
        const distance = Math.abs(slide.offsetLeft - currentLeft);
        if (distance < nearestDistance) {
          nearestDistance = distance;
          nearestIndex = index;
        }
      });

      activeIndex = nearestIndex;
    };

    const stop = () => {
      if (intervalId !== null) {
        window.clearInterval(intervalId);
        intervalId = null;
      }
    };

    const start = () => {
      stop();
      intervalId = window.setInterval(() => {
        const nextIndex = (activeIndex + 1) % slides.length;
        goToSlide(nextIndex);
      }, 5000);
    };

    track.addEventListener('scroll', () => {
      if (scrollTimer !== null) {
        window.clearTimeout(scrollTimer);
      }

      scrollTimer = window.setTimeout(syncIndexFromScroll, 120);
    });

    galleryRoot.addEventListener('pointerenter', stop);
    galleryRoot.addEventListener('pointerleave', start);
    galleryRoot.addEventListener('focusin', stop);
    galleryRoot.addEventListener('focusout', start);

    start();

    return undefined;
  };

  document.querySelectorAll('[data-auto-scroll-gallery]').forEach((galleryRoot) => {
    startAutoScrollGallery(galleryRoot);
  });
</script>

---
import DialogShell from '@/components/DialogShell.astro';
import TechnologyBadge from '@/components/home/TechnologyBadge.astro';
import { technologyIconDirectory, type Technology } from '@/features/home/content';
import { withBase } from '@/utils/base-path';

type Props = {
  technologies: Technology[];
  panelTitle?: string;
  panelIntro?: string;
  ctaLabel?: string;
  ctaHref?: string;
};

const {
  technologies,
  panelTitle = 'Skills and tooling',
  panelIntro =
    'A curated recruiter-facing skill set across gameplay delivery, backend systems, integrations, and platform operations.',
  ctaLabel = 'View full skills map',
  ctaHref = 'skills',
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const getSkillId = (technology: Technology) =>
  technology.id ?? technology.name.toLowerCase().replace(/[^a-z0-9]+/g, '-');

const technologyDetails = technologies.map((technology) => ({
  id: getSkillId(technology),
  name: technology.name,
  summary: technology.summary ?? `TODO: Add a short summary for ${technology.name}.`,
  experience: technology.experience ?? 'TODO: Add work experience details from LinkedIn.',
  iconUrl: technology.iconFile
    ? withBase(baseUrl, `${technologyIconDirectory}/${technology.iconFile}`)
    : null,
  iconStyle: technology.iconStyle ?? null,
  trademarkDisclaimer: technology.trademarkDisclaimer ?? null,
}));
---

<div class="section-card hero-tech-panel rounded-[1.75rem] p-6">
  <p class="text-sm font-semibold uppercase tracking-[0.18em] muted">
    {panelTitle}
  </p>
  <p class="mt-3 max-w-md text-lg font-semibold">
    {panelIntro}
  </p>
  <div class="tech-badge-grid mt-5">
    {
      technologies.map((technology) => (
        <TechnologyBadge technology={technology} skillId={getSkillId(technology)} />
      ))
    }
  </div>
  <div class="mt-4 flex flex-wrap items-center gap-3">
    <p class="tech-badge-hint text-xs muted">Tap or click any icon to open skill details.</p>
    <a class="button-secondary py-2" href={withBase(baseUrl, ctaHref)}>{ctaLabel}</a>
  </div>
</div>

<DialogShell
  id="skill-dialog"
  labelledby="skill-dialog-title"
  describedby="skill-dialog-summary skill-dialog-experience"
  class="site-dialog-compact"
  closeDataAttribute="data-skill-close"
  closeAriaLabel="Close skill details"
>
  <Fragment slot="heading">
    <div class="site-dialog-title-row">
      <span class="skill-dialog-icon-wrap" id="skill-dialog-icon-wrap" aria-hidden="true" hidden>
        <img class="skill-dialog-icon" id="skill-dialog-icon" alt="" width="28" height="28" decoding="async" />
      </span>
      <h3 class="site-dialog-title site-dialog-title-small" id="skill-dialog-title"></h3>
    </div>
    <p class="site-dialog-description">Skill context and applied experience.</p>
  </Fragment>

  <section class="site-dialog-panel">
    <p class="site-dialog-panel-label">Overview</p>
    <p class="site-dialog-panel-value" id="skill-dialog-summary"></p>
  </section>
  <section class="site-dialog-panel">
    <p class="site-dialog-panel-label">Experience</p>
    <p class="site-dialog-panel-value" id="skill-dialog-experience"></p>
  </section>
  <p slot="disclaimer" class="site-dialog-disclaimer" id="skill-dialog-disclaimer" hidden></p>
</DialogShell>

<script is:inline define:vars={{ technologyDetails }}>
  const detailsMap = new Map(technologyDetails.map((technology) => [technology.id, technology]));
  const skillDialog = document.getElementById('skill-dialog');
  const titleElement = document.getElementById('skill-dialog-title');
  const summaryElement = document.getElementById('skill-dialog-summary');
  const experienceElement = document.getElementById('skill-dialog-experience');
  const iconWrapElement = document.getElementById('skill-dialog-icon-wrap');
  const iconElement = document.getElementById('skill-dialog-icon');
  const disclaimerElement = document.getElementById('skill-dialog-disclaimer');
  const closeButton = skillDialog?.querySelector('[data-skill-close]');
  const triggers = document.querySelectorAll('[data-skill-trigger]');

  const openSkillDialog = (skillId) => {
    if (!skillDialog || !titleElement || !summaryElement || !experienceElement) return;
    const details = detailsMap.get(skillId);
    if (!details) return;

    titleElement.textContent = details.name;
    summaryElement.textContent = details.summary;
    experienceElement.textContent = details.experience;
    if (iconElement && iconWrapElement) {
      if (details.iconUrl) {
        iconElement.setAttribute('src', details.iconUrl);
        iconWrapElement.classList.toggle('skill-dialog-icon-wrap-wide', details.iconStyle === 'wide');
        iconElement.classList.toggle('skill-dialog-icon-wide', details.iconStyle === 'wide');
        iconWrapElement.removeAttribute('hidden');
      } else {
        iconElement.removeAttribute('src');
        iconWrapElement.classList.remove('skill-dialog-icon-wrap-wide');
        iconElement.classList.remove('skill-dialog-icon-wide');
        iconWrapElement.setAttribute('hidden', '');
      }
    }

    if (disclaimerElement) {
      if (details.trademarkDisclaimer) {
        disclaimerElement.textContent = details.trademarkDisclaimer;
        disclaimerElement.removeAttribute('hidden');
      } else {
        disclaimerElement.textContent = '';
        disclaimerElement.setAttribute('hidden', '');
      }
    }

    if (typeof skillDialog.showModal === 'function') {
      if (skillDialog.open) return;
      skillDialog.showModal();
      return;
    }

    skillDialog.setAttribute('open', '');
  };

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const skillId = trigger.getAttribute('data-skill-id');
      if (!skillId) return;
      openSkillDialog(skillId);
    });

    trigger.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter' && event.key !== ' ') return;
      event.preventDefault();
      const skillId = trigger.getAttribute('data-skill-id');
      if (!skillId) return;
      openSkillDialog(skillId);
    });
  });

  closeButton?.addEventListener('click', () => {
    if (!skillDialog) return;
    if (!skillDialog.open) return;
    if (typeof skillDialog.close === 'function') {
      skillDialog.close();
      return;
    }

    skillDialog.removeAttribute('open');
  });

  skillDialog?.addEventListener('click', (event) => {
    if (event.target === skillDialog) {
      if (typeof skillDialog.close === 'function') {
        skillDialog.close();
        return;
      }

      skillDialog.removeAttribute('open');
    }
  });
</script>

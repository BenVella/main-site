---
type Technology = {
  shortLabel: string;
  name: string;
};

type Props = {
  technologies: Technology[];
};

const { technologies } = Astro.props;
---

<div class="section-card hero-tech-panel rounded-[1.75rem] p-6">
  <p class="text-sm font-semibold uppercase tracking-[0.18em] muted">
    Technology toolkit
  </p>
  <p class="mt-3 max-w-md text-lg font-semibold">
    Space for the platforms and tooling that support both game delivery and backend work.
  </p>
  <div class="mt-5 flex flex-wrap gap-3">
    {
      technologies.map((technology, index) => (
        <div class="tech-badge" style={`--badge-delay: ${index * 120}ms;`}>
          <span class="tech-badge-mark">{technology.shortLabel}</span>
          <span class="tech-badge-name">{technology.name}</span>
        </div>
      ))
    }
  </div>
</div>

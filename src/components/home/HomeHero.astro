---
import TechnologyStrip from '@/components/home/TechnologyStrip.astro';
import { heroHighlights, heroTechnologies, homeHero } from '@/features/home/content';
import { withBase } from '@/utils/base-path';

type Props = {
  githubUrl: string;
  linkedinUrl: string;
};

const { githubUrl, linkedinUrl } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<section class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
  <div class="section-card hero-card rounded-[2rem] p-8 md:p-10">
    <p class="eyebrow">{homeHero.eyebrow}</p>
    <h1 class="mt-4 max-w-2xl text-4xl font-semibold tracking-tight md:text-5xl">
      {homeHero.title}
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-8 muted">{homeHero.intro}</p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a class="button-primary" href={withBase(baseUrl, 'projects')}>
        Explore projects
      </a>
      <a class="button-secondary gap-2" href={linkedinUrl} target="_blank" rel="noreferrer">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
          <path d="M4.98 3.5C4.98 4.88 3.87 6 2.49 6S0 4.88 0 3.5 1.11 1 2.49 1s2.49 1.12 2.49 2.5ZM.5 8h4V23h-4V8Zm7 0h3.83v2.05h.06c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.77 2.65 4.77 6.1V23h-4v-7.76c0-1.85-.03-4.24-2.58-4.24-2.58 0-2.97 2.02-2.97 4.11V23h-4V8Z"/>
        </svg>
        LinkedIn
      </a>
      <a class="button-secondary gap-2" href={githubUrl} target="_blank" rel="noreferrer">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
          <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.02c-3.34.73-4.04-1.61-4.04-1.61a3.18 3.18 0 0 0-1.34-1.75c-1.1-.76.08-.75.08-.75a2.53 2.53 0 0 1 1.85 1.25 2.56 2.56 0 0 0 3.5 1 2.56 2.56 0 0 1 .76-1.6c-2.66-.3-5.47-1.33-5.47-5.91a4.63 4.63 0 0 1 1.23-3.22 4.3 4.3 0 0 1 .12-3.18s1-.32 3.3 1.23a11.35 11.35 0 0 1 6 0c2.3-1.55 3.29-1.23 3.29-1.23a4.3 4.3 0 0 1 .12 3.18 4.62 4.62 0 0 1 1.23 3.22c0 4.59-2.81 5.6-5.49 5.9a2.86 2.86 0 0 1 .82 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 .5Z"/>
        </svg>
        GitHub
      </a>
    </div>
  </div>

  <aside class="space-y-4">
    <TechnologyStrip technologies={heroTechnologies} />
    {
      heroHighlights.map((item) => (
        <div class="section-card rounded-[1.75rem] p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] muted">
            {item.label}
          </p>
          <p class="mt-3 text-xl font-semibold">{item.value}</p>
        </div>
      ))
    }
  </aside>
</section>

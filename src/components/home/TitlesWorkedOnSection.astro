---
import DialogShell from '@/components/DialogShell.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { workedTitles } from '@/features/home/titles-worked-on';
import { withBase } from '@/utils/base-path';

const baseUrl = import.meta.env.BASE_URL;
const titleDetails = workedTitles.map((entry) => ({
  ...entry,
  thumbnailUrl: withBase(baseUrl, entry.thumbnail.src),
}));
---

<section class="mt-20" id="titles-worked-on">
  <SectionHeading
    eyebrow="Titles Worked On"
    title="Titles Worked On"
    intro="Selected commercial game work across client, backend, systems, and platform engineering."
  />

  <div class="titles-grid">
    {
      workedTitles.map((entry) => (
        <button type="button" class="titles-card" data-title-trigger data-title-id={entry.id} aria-haspopup="dialog">
          <img
            src={withBase(baseUrl, entry.thumbnail.src)}
            alt={entry.thumbnail.alt}
            loading="lazy"
            class="titles-card-image"
          />
          <span class="titles-card-title">{entry.title}</span>
        </button>
      ))
    }
  </div>
</section>

<DialogShell
  id="titles-dialog"
  labelledby="titles-dialog-title"
  describedby="titles-dialog-tagline titles-dialog-contribution"
  closeDataAttribute="data-title-close"
  closeAriaLabel="Close title details"
  panelsClass="site-dialog-panels-two-column"
>
  <Fragment slot="heading">
    <h3 class="site-dialog-title display-face" id="titles-dialog-title"></h3>
    <p class="site-dialog-description" id="titles-dialog-tagline"></p>
  </Fragment>

  <Fragment slot="media">
    <div class="site-dialog-media">
      <img id="titles-dialog-image" class="site-dialog-image" alt="" width="1200" height="675" decoding="async" />
    </div>
  </Fragment>

  <section class="site-dialog-panel">
    <p class="site-dialog-panel-label">Platform</p>
    <p class="site-dialog-panel-value" id="titles-dialog-platform"></p>
  </section>
  <section class="site-dialog-panel">
    <p class="site-dialog-panel-label">Role</p>
    <p class="site-dialog-panel-value" id="titles-dialog-role"></p>
  </section>
  <section class="site-dialog-panel site-dialog-panel-full">
    <p class="site-dialog-panel-label">Contribution</p>
    <p class="site-dialog-panel-value" id="titles-dialog-contribution"></p>
  </section>
</DialogShell>

<script is:inline define:vars={{ titleDetails }}>
  const detailsMap = new Map(titleDetails.map((entry) => [entry.id, entry]));
  const titlesDialog = document.getElementById('titles-dialog');
  const titleElement = document.getElementById('titles-dialog-title');
  const taglineElement = document.getElementById('titles-dialog-tagline');
  const platformElement = document.getElementById('titles-dialog-platform');
  const roleElement = document.getElementById('titles-dialog-role');
  const contributionElement = document.getElementById('titles-dialog-contribution');
  const imageElement = document.getElementById('titles-dialog-image');
  const closeButton = titlesDialog?.querySelector('[data-title-close]');
  const triggers = document.querySelectorAll('[data-title-trigger]');
  let lastFocusedTrigger = null;

  const closeDialog = () => {
    if (!titlesDialog || !titlesDialog.open) return;

    if (typeof titlesDialog.close === 'function') {
      titlesDialog.close();
    } else {
      titlesDialog.removeAttribute('open');
    }

    if (lastFocusedTrigger instanceof HTMLElement) {
      lastFocusedTrigger.focus();
    }
  };

  const openDialog = (titleId, triggerElement) => {
    if (
      !titlesDialog ||
      !titleElement ||
      !taglineElement ||
      !platformElement ||
      !roleElement ||
      !contributionElement ||
      !imageElement
    ) {
      return;
    }

    const details = detailsMap.get(titleId);
    if (!details) return;

    titleElement.textContent = details.title;
    taglineElement.textContent = details.tagline;
    platformElement.textContent = details.platform;
    roleElement.textContent = details.role;
    contributionElement.textContent = details.contribution;
    imageElement.setAttribute('src', details.thumbnailUrl);
    imageElement.setAttribute('alt', details.thumbnail.alt);

    lastFocusedTrigger = triggerElement instanceof HTMLElement ? triggerElement : null;

    if (typeof titlesDialog.showModal === 'function') {
      if (titlesDialog.open) return;
      titlesDialog.showModal();
      return;
    }

    titlesDialog.setAttribute('open', '');
  };

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const titleId = trigger.getAttribute('data-title-id');
      if (!titleId) return;
      openDialog(titleId, trigger);
    });
  });

  closeButton?.addEventListener('click', closeDialog);

  titlesDialog?.addEventListener('click', (event) => {
    if (event.target === titlesDialog) {
      closeDialog();
    }
  });

  titlesDialog?.addEventListener('cancel', (event) => {
    event.preventDefault();
    closeDialog();
  });
</script>

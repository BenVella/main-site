---
import { technologyIconDirectory, type Technology } from '@/features/home/content';
import { withBase } from '@/utils/base-path';

type Props = {
  technology: Technology;
  delayMs?: number;
};

const { technology, delayMs = 0 } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const getTechnologyIconPath = (iconFile: string) => withBase(baseUrl, `${technologyIconDirectory}/${iconFile}`);
---

<div class="tech-badge" style={`--badge-delay: ${delayMs}ms;`}>
  {
    technology.iconFile ? (
      <span class="tech-badge-mark tech-badge-mark-icon" aria-hidden="true">
        <img
          class="tech-badge-icon"
          src={getTechnologyIconPath(technology.iconFile)}
          alt=""
          width="20"
          height="20"
          decoding="async"
        />
      </span>
    ) : (
      <span class="tech-badge-mark" aria-hidden="true">{technology.shortLabel}</span>
    )
  }
  <span class="tech-badge-name">{technology.name}</span>
</div>

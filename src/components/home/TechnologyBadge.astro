---
import { technologyIconDirectory, type Technology } from '@/features/home/content';
import { withBase } from '@/utils/base-path';

type Props = {
  technology: Technology;
  skillId?: string;
  delayMs?: number;
};

const { technology, skillId = technology.name.toLowerCase().replace(/[^a-z0-9]+/g, '-'), delayMs = 0 } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const getTechnologyIconPath = (iconFile: string) => withBase(baseUrl, `${technologyIconDirectory}/${iconFile}`);
const hasIcon = Boolean(technology.iconFile);
const iconStyleClass = technology.iconStyle === 'wide' ? 'tech-badge-mark-wide' : 'tech-badge-mark-symbol';
const iconImageClass = technology.iconStyle === 'wide' ? 'tech-badge-icon-wide' : '';
---

<button
  type="button"
  class:list={['tech-badge', hasIcon && 'tech-badge-icon-only']}
  style={`--badge-delay: ${delayMs}ms;`}
  title={`Open details for ${technology.name}`}
  data-skill-trigger
  data-skill-id={skillId}
  aria-haspopup="dialog"
>
  {
    hasIcon ? (
      <span class={`tech-badge-mark tech-badge-mark-icon ${iconStyleClass}`} aria-hidden="true">
        <img
          class={`tech-badge-icon ${iconImageClass}`}
          src={getTechnologyIconPath(technology.iconFile!)}
          alt=""
          width="20"
          height="20"
          decoding="async"
        />
      </span>
      <span class="tech-badge-indicator" aria-hidden="true">↗</span>
    ) : (
      <span class="tech-badge-mark" aria-hidden="true">{technology.shortLabel}</span>
    )
  }
  {
    hasIcon ? (
      <span class="sr-only">{technology.name}</span>
    ) : (
      <span class="tech-badge-name">{technology.name}</span>
    )
  }
</button>

---
import type { CollectionEntry } from 'astro:content';

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<article class="section-card rounded-[1.75rem] p-6">
  <p class="text-sm muted">
    {post.data.pubDate.toLocaleDateString('en-GB', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })}
  </p>
  <h3 class="display-face mt-3 text-2xl font-semibold">{post.data.title}</h3>
  <p class="mt-4 leading-7 muted">{post.data.description}</p>
  <div class="mt-5 flex flex-wrap gap-2">
    {
      post.data.tags.map((tag) => (
        <span class="rounded-full bg-white/80 px-3 py-1 text-xs font-medium text-stone-700">
          {tag}
        </span>
      ))
    }
  </div>
  <a
    href={`${baseUrl}blog/${post.slug}`}
    class="mt-6 inline-flex items-center text-sm font-semibold"
    style="color: var(--accent);"
  >
    Read article
  </a>
</article>

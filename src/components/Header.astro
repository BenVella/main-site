---
import { siteConfig } from '@/site.config';
import { withBase } from '@/utils/base-path';
import {
  getStagingManifestUrl,
  getStagingRootPath,
  parseStagingLocation,
} from '@/utils/staging-preview';

const nav = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/cv', label: 'CV' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
const baseUrl = import.meta.env.BASE_URL;
const isStaging = import.meta.env.PUBLIC_SITE_ENV === 'staging';
const homeHref = withBase(baseUrl);
const normalizePath = (path: string) => {
  if (path === '/') return path;

  return path.replace(/\/$/, '');
};
const stagingRootPath = getStagingRootPath(import.meta.env.PUBLIC_STAGING_ROOT_PATH);
const stagingManifestUrl = getStagingManifestUrl(import.meta.env.PUBLIC_STAGING_ROOT_PATH);
const stagingLocation = parseStagingLocation(currentPath, import.meta.env.PUBLIC_STAGING_ROOT_PATH);
---

<header class="page-shell pt-6">
  <div class="section-card rounded-[2rem] px-6 py-5">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div class="flex flex-wrap items-center gap-3">
        <a href={homeHref} class="flex flex-col">
          <span class="display-face text-2xl font-semibold">{siteConfig.name}</span>
          <span class="text-sm muted">Software engineer</span>
        </a>
        {
          isStaging && (
            <a class="staging-badge" href={stagingRootPath} aria-label="Return to staging root">
              Preview / Staging
            </a>
          )
        }
      </div>
      <div class="flex flex-col gap-3 md:items-end">
        {
          isStaging && (
            <div
              class="preview-switcher"
              data-preview-switcher
              data-manifest-url={stagingManifestUrl}
              data-staging-root-path={stagingRootPath}
              data-current-path={currentPath}
            >
              <label class="preview-switcher-label" for="staging-preview-select">
                Open PR previews
              </label>
              <select
                id="staging-preview-select"
                class="preview-switcher-select"
                aria-label="Switch between staging previews"
                disabled
              >
                <option>
                  {stagingLocation.previewPathSegment
                    ? `Loading ${stagingLocation.previewPathSegment}...`
                    : 'Loading previews...'}
                </option>
              </select>
            </div>
          )
        }
        <nav aria-label="Primary navigation">
          <ul class="flex flex-wrap items-center gap-2 text-sm font-medium md:justify-end">
            {
              nav.map((item) => {
                const href = item.href === '/' ? homeHref : withBase(baseUrl, item.href);
                const normalizedHref = normalizePath(href);
                const normalizedCurrentPath = normalizePath(currentPath);
                const active =
                  item.href === '/'
                    ? normalizedCurrentPath === normalizedHref
                    : normalizedCurrentPath === normalizedHref || normalizedCurrentPath.startsWith(`${normalizedHref}/`);

                return (
                  <li>
                    <a
                      href={href}
                      class:list={[
                        'nav-link',
                        active && 'nav-link-active',
                      ]}
                    >
                      {item.label}
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </nav>
      </div>
    </div>
  </div>
</header>

{
  isStaging && (
    <script>
      import { initStagingPreviewSwitcher } from '@/scripts/staging-preview-switcher';

      initStagingPreviewSwitcher();
    </script>
  )
}

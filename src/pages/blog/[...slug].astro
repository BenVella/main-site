---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout pageTitle={post.data.title} pageDescription={post.data.description}>
  <article class="section-card rounded-[2rem] p-8 md:p-10">
    <p class="eyebrow">Blog</p>
    <h1 class="display-face mt-4 text-4xl font-semibold md:text-6xl">
      {post.data.title}
    </h1>
    <p class="mt-4 max-w-3xl text-lg leading-8 muted">{post.data.description}</p>
    <div class="mt-6 flex flex-wrap gap-2">
      {
        post.data.tags.map((tag) => (
          <span class="chip">
            {tag}
          </span>
        ))
      }
    </div>
    <p class="mt-6 text-sm muted">
      Published{' '}
      {post.data.pubDate.toLocaleDateString('en-GB', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })}
    </p>
    <div class="rich-prose mt-10">
      <Content />
    </div>
  </article>
</BaseLayout>

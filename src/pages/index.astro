---
import { getCollection } from 'astro:content';
import PostCard from '@/components/PostCard.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { featuredProjects } from '@/features/projects/service';
import {
  education,
  experience,
  heroHighlights,
  heroTechnologies,
  homeHero,
  siteConfig,
  strengths,
} from '@/site.config';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 2);
---

<BaseLayout
  pageTitle="Software Engineer"
  pageDescription="Portfolio, project case studies, and writing by Bennet Vella."
>
  <section class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
    <div class="section-card hero-card rounded-[2rem] p-8 md:p-10">
      <p class="eyebrow">{homeHero.eyebrow}</p>
      <h1 class="display-face mt-4 max-w-3xl text-5xl font-semibold tracking-tight md:text-7xl">
        {homeHero.title}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 muted">{homeHero.intro}</p>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {
          homeHero.supportingPoints.map((point) => (
            <div class="hero-note rounded-[1.5rem] p-4">
              <p class="leading-7">{point}</p>
            </div>
          ))
        }
      </div>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="button-primary" href={`${import.meta.env.BASE_URL}projects`}>
          Explore projects
        </a>
        <a class="button-secondary" href={siteConfig.linkedin} target="_blank" rel="noreferrer">
          LinkedIn profile
        </a>
      </div>
    </div>

    <aside class="space-y-4">
      <div class="section-card hero-tech-panel rounded-[1.75rem] p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] muted">
          Technology toolkit
        </p>
        <p class="mt-3 max-w-md text-lg font-semibold">
          Space for the platforms and tooling that support both game delivery and backend work.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          {
            heroTechnologies.map((technology, index) => (
              <div class="tech-badge" style={`--badge-delay: ${index * 120}ms;`}>
                <span class="tech-badge-mark">{technology.shortLabel}</span>
                <span class="tech-badge-name">{technology.name}</span>
              </div>
            ))
          }
        </div>
      </div>
      {
        heroHighlights.map((item) => (
          <div class="section-card rounded-[1.75rem] p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] muted">
              {item.label}
            </p>
            <p class="mt-3 text-xl font-semibold">{item.value}</p>
          </div>
        ))
      }
    </aside>
  </section>

  <section class="mt-20">
    <SectionHeading
      eyebrow="Strengths"
      title="A portfolio shaped by shipping work, not just demo code."
      intro="These focus areas reflect the engineering work I have spent the most time shipping across product, platform, and delivery contexts."
    />
    <div class="grid gap-4 md:grid-cols-2">
      {
        strengths.map((strength) => (
          <div class="section-card rounded-[1.5rem] p-6">
            <p class="leading-7">{strength}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mt-20">
    <SectionHeading
      eyebrow="Projects"
      title="Selected case studies"
      intro="These are the projects and work areas that best represent how I approach software engineering."
    />
    <div class="grid gap-5 lg:grid-cols-3">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="mt-20 grid gap-8 lg:grid-cols-2">
    <div>
      <SectionHeading
        eyebrow="Experience"
        title="Professional path"
        intro="Selected roles and responsibilities presented as concise summaries of the work I have delivered."
      />
      <div class="space-y-4">
        {
          experience.map((item) => (
            <div class="section-card rounded-[1.5rem] p-6">
              <p class="text-sm font-semibold muted">{item.period}</p>
              <h3 class="mt-2 text-xl font-semibold">{item.title}</h3>
              <p class="mt-1 text-sm uppercase tracking-[0.16em] muted">{item.company}</p>
              <p class="mt-4 leading-7 muted">{item.summary}</p>
            </div>
          ))
        }
      </div>
    </div>
    <div>
      <SectionHeading
        eyebrow="Education"
        title="Academic background"
        intro="Formal training that supports my work across systems, software engineering, and applied technical problem-solving."
      />
      <div class="space-y-4">
        {
          education.map((item) => (
            <div class="section-card rounded-[1.5rem] p-6">
              <p class="text-sm font-semibold muted">{item.period}</p>
              <h3 class="mt-2 text-xl font-semibold">{item.title}</h3>
              <p class="mt-1 leading-7 muted">{item.institution}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mt-20">
    <SectionHeading
      eyebrow="Writing"
      title="Recent notes"
      intro="Notes on software engineering, delivery constraints, backend systems, and related technical work."
    />
    <div class="grid gap-5 md:grid-cols-2">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>

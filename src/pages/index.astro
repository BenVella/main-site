---
import { getCollection } from 'astro:content';
import HomeHero from '@/components/home/HomeHero.astro';
import PostCard from '@/components/PostCard.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import TitlesWorkedOnSection from '@/components/home/TitlesWorkedOnSection.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { education, experience, siteConfig, strengths } from '@/site.config';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 2);
---

<BaseLayout
  pageTitle="Lead Game Programmer"
  pageDescription="Portfolio, project case studies, and writing on game systems, backend multiplayer, and technical delivery by Bennet Vella."
>
  <HomeHero githubUrl={siteConfig.github} linkedinUrl={siteConfig.linkedin} />

  <TitlesWorkedOnSection />

  <section class="mt-20">
    <SectionHeading
      eyebrow="Writing"
      title="Recent notes"
      intro="Notes on software engineering, delivery constraints, backend systems, and related technical work."
    />
    <div class="grid gap-5 md:grid-cols-2">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="mt-20">
    <SectionHeading
      eyebrow="Strengths"
      title="A portfolio shaped by shipping work, not just demo code."
      intro="These focus areas reflect the engineering work I have spent the most time shipping across product, platform, and delivery contexts."
    />
    <div class="grid gap-4 md:grid-cols-2">
      {
        strengths.map((strength) => (
          <div class="section-card rounded-[1.5rem] p-6">
            <p class="leading-7">{strength}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mt-20 grid gap-8 lg:grid-cols-2">
    <div>
      <SectionHeading
        eyebrow="Experience"
        title="Professional path"
        intro="Selected roles and responsibilities presented as concise summaries of the work I have delivered."
      />
      <div class="space-y-4">
        {
          experience.map((item) => (
            <div class="section-card rounded-[1.5rem] p-6">
              <p class="text-sm font-semibold muted">{item.period}</p>
              <h3 class="mt-2 text-xl font-semibold">{item.title}</h3>
              <p class="mt-1 text-sm uppercase tracking-[0.16em] muted">{item.company}</p>
              <p class="mt-4 leading-7 muted">{item.summary}</p>
            </div>
          ))
        }
      </div>
    </div>
    <div>
      <SectionHeading
        eyebrow="Education"
        title="Academic background"
        intro="Formal training that supports my work across systems, software engineering, and applied technical problem-solving."
      />
      <div class="space-y-4">
        {
          education.map((item) => (
            <div class="section-card rounded-[1.5rem] p-6">
              <p class="text-sm font-semibold muted">{item.period}</p>
              <h3 class="mt-2 text-xl font-semibold">{item.title}</h3>
              <p class="mt-1 leading-7 muted">{item.institution}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

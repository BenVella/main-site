---
import AutoScrollGallery from '@/components/AutoScrollGallery.astro';
import DialogShell from '@/components/DialogShell.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import TechnologyBadge from '@/components/home/TechnologyBadge.astro';
import { technologyIconDirectory } from '@/features/home/content';
import { fullSkillTechnologies, skillCategoryEntries } from '@/features/skills/catalog';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/utils/base-path';

const baseUrl = import.meta.env.BASE_URL;

const skillDetails = fullSkillTechnologies.map((technology) => ({
  id: technology.id ?? technology.name.toLowerCase().replace(/[^a-z0-9]+/g, '-'),
  name: technology.name,
  summary: technology.summary ?? `TODO: Add a short summary for ${technology.name}.`,
  experience: technology.experience ?? 'TODO: Add work experience details from LinkedIn.',
  iconUrl: technology.iconFile
    ? withBase(baseUrl, `${technologyIconDirectory}/${technology.iconFile}`)
    : null,
  iconStyle: technology.iconStyle ?? null,
  trademarkDisclaimer: technology.trademarkDisclaimer ?? null,
}));
---

<BaseLayout
  pageTitle="Skills"
  pageDescription="Full skills map covering game client, backend, cloud integration, DevOps, and delivery tooling experience."
>
  <section>
    <SectionHeading
      eyebrow="Skills"
      title="Complete capability map"
      intro="Category-based skills grouped by capability area, with quick cues for where each area has been applied in shipped work."
    />
  </section>

  <section class="mt-10 skills-panel-grid" data-skills-category-grid>
    {
      skillCategoryEntries.map((category) => (
        <article class="skills-category-card" id={category.id}>
          <AutoScrollGallery items={category.collage} galleryId={`skills-gallery-${category.id}`} />

          <div class="skills-category-content">
            <h2 class="skills-category-title display-face">{category.title}</h2>
            <p class="skills-category-intro">{category.intro}</p>

            <div class="tech-badge-grid skills-category-skill-grid" aria-label={`${category.title} skill icons`}>
              {category.skills.map((technology) => (
                <TechnologyBadge technology={technology} skillId={technology.id} />
              ))}
            </div>

            <div class="skills-category-usage">
              <p class="skills-category-usage-label">{category.usageLabel ?? 'Where used'}</p>
              <ul class="skills-category-usage-list">
                {category.whereUsed.map((usage) => (
                  <li>
                    {usage.href ? (
                      <a href={withBase(baseUrl, usage.href)} class="skills-category-usage-item">
                        <span class="skills-category-usage-item-title">{usage.label}</span>
                        {usage.description ? <span class="skills-category-usage-item-description">{usage.description}</span> : null}
                      </a>
                    ) : (
                      <div class="skills-category-usage-item">
                        <span class="skills-category-usage-item-title">{usage.label}</span>
                        {usage.description ? <span class="skills-category-usage-item-description">{usage.description}</span> : null}
                      </div>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </article>
      ))
    }
  </section>

  <DialogShell
    id="skills-page-dialog"
    labelledby="skills-page-dialog-title"
    describedby="skills-page-dialog-summary skills-page-dialog-experience"
    class="site-dialog-compact"
    closeDataAttribute="data-skills-page-close"
    closeAriaLabel="Close skill details"
  >
    <Fragment slot="heading">
      <div class="site-dialog-title-row">
        <span class="skill-dialog-icon-wrap" id="skills-page-dialog-icon-wrap" aria-hidden="true" hidden>
          <img class="skill-dialog-icon" id="skills-page-dialog-icon" alt="" width="28" height="28" decoding="async" />
        </span>
        <h3 class="site-dialog-title site-dialog-title-small" id="skills-page-dialog-title"></h3>
      </div>
      <p class="site-dialog-description">Skill context and applied experience.</p>
    </Fragment>

    <section class="site-dialog-panel">
      <p class="site-dialog-panel-label">Overview</p>
      <p class="site-dialog-panel-value" id="skills-page-dialog-summary"></p>
    </section>
    <section class="site-dialog-panel">
      <p class="site-dialog-panel-label">Experience</p>
      <p class="site-dialog-panel-value" id="skills-page-dialog-experience"></p>
    </section>
    <p slot="disclaimer" class="site-dialog-disclaimer" id="skills-page-dialog-disclaimer" hidden></p>
  </DialogShell>

  <script is:inline define:vars={{ skillDetails }}>
    const detailsMap = new Map(skillDetails.map((technology) => [technology.id, technology]));
    const skillDialog = document.getElementById('skills-page-dialog');
    const titleElement = document.getElementById('skills-page-dialog-title');
    const summaryElement = document.getElementById('skills-page-dialog-summary');
    const experienceElement = document.getElementById('skills-page-dialog-experience');
    const iconWrapElement = document.getElementById('skills-page-dialog-icon-wrap');
    const iconElement = document.getElementById('skills-page-dialog-icon');
    const disclaimerElement = document.getElementById('skills-page-dialog-disclaimer');
    const closeButton = skillDialog?.querySelector('[data-skills-page-close]');
    const categorySection = document.querySelector('[data-skills-category-grid]');

    const openSkillDialog = (skillId) => {
      if (!skillDialog || !titleElement || !summaryElement || !experienceElement) return;
      const details = detailsMap.get(skillId);
      if (!details) return;

      titleElement.textContent = details.name;
      summaryElement.textContent = details.summary;
      experienceElement.textContent = details.experience;

      if (iconElement && iconWrapElement) {
        if (details.iconUrl) {
          iconElement.setAttribute('src', details.iconUrl);
          iconWrapElement.classList.toggle('skill-dialog-icon-wrap-wide', details.iconStyle === 'wide');
          iconElement.classList.toggle('skill-dialog-icon-wide', details.iconStyle === 'wide');
          iconWrapElement.removeAttribute('hidden');
        } else {
          iconElement.removeAttribute('src');
          iconWrapElement.classList.remove('skill-dialog-icon-wrap-wide');
          iconElement.classList.remove('skill-dialog-icon-wide');
          iconWrapElement.setAttribute('hidden', '');
        }
      }

      if (disclaimerElement) {
        if (details.trademarkDisclaimer) {
          disclaimerElement.textContent = details.trademarkDisclaimer;
          disclaimerElement.removeAttribute('hidden');
        } else {
          disclaimerElement.textContent = '';
          disclaimerElement.setAttribute('hidden', '');
        }
      }

      if (typeof skillDialog.showModal === 'function') {
        if (skillDialog.open) return;
        skillDialog.showModal();
        return;
      }

      skillDialog.setAttribute('open', '');
    };

    categorySection?.querySelectorAll('[data-skill-trigger]').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const skillId = trigger.getAttribute('data-skill-id');
        if (!skillId) return;
        openSkillDialog(skillId);
      });

      trigger.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' && event.key !== ' ') return;
        event.preventDefault();
        const skillId = trigger.getAttribute('data-skill-id');
        if (!skillId) return;
        openSkillDialog(skillId);
      });
    });

    closeButton?.addEventListener('click', () => {
      if (!skillDialog || !skillDialog.open) return;
      if (typeof skillDialog.close === 'function') {
        skillDialog.close();
        return;
      }

      skillDialog.removeAttribute('open');
    });

    skillDialog?.addEventListener('click', (event) => {
      if (event.target === skillDialog) {
        if (typeof skillDialog.close === 'function') {
          skillDialog.close();
          return;
        }

        skillDialog.removeAttribute('open');
      }
    });
  </script>
</BaseLayout>

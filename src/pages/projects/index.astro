---
import SectionHeading from '@/components/SectionHeading.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { projects } from '@/features/projects/service';
import { withBase } from '@/utils/base-path';

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout
  pageTitle="Projects"
  pageDescription="Framed project snapshots from Exient with on-demand detail popups."
>
  <SectionHeading
    eyebrow="Projects"
    title="Framed project snapshots"
    intro="A lightweight gallery view with focused captions. Open any project for a deeper technical popup."
  />

  <div class="grid gap-5 md:grid-cols-2">
    {
      projects.map((project) => (
        <article class="section-card overflow-hidden rounded-[1.75rem] p-4">
          <img
            src={withBase(baseUrl, project.image.src)}
            alt={project.image.alt}
            loading="lazy"
            class="h-56 w-full rounded-2xl object-cover"
          />
          <div class="px-1 pb-2 pt-4">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] muted">{project.company}</p>
            <h3 class="mt-2 display-face text-2xl font-semibold">{project.title}</h3>
            <p class="mt-2 text-sm muted">{project.role} · {project.period}</p>
            <p class="mt-4 leading-7 muted">{project.caption}</p>
            <button
              type="button"
              class="button-secondary mt-5"
              data-project-modal-trigger={project.slug}
              aria-haspopup="dialog"
              aria-controls={`project-modal-${project.slug}`}
            >
              View deeper details
            </button>
          </div>
        </article>
      ))
    }
  </div>

  {
    projects.map((project) => (
      <dialog
        class="skill-dialog project-dialog"
        data-project-modal={project.slug}
        id={`project-modal-${project.slug}`}
        aria-labelledby={`project-modal-title-${project.slug}`}
      >
        <article class="skill-dialog-card">
          <header class="skill-dialog-header">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.16em] muted">{project.company}</p>
              <h2 class="skill-dialog-title mt-2" id={`project-modal-title-${project.slug}`}>{project.title}</h2>
              <p class="mt-2 text-sm muted">{project.role} · {project.period}</p>
            </div>
            <button type="button" class="project-dialog-close" data-project-modal-close>
              Close
            </button>
          </header>

          <hr class="skill-dialog-rule" />
          <p class="skill-dialog-summary">{project.details.summary}</p>

          <hr class="skill-dialog-rule" />
          <h3 class="project-dialog-section-title">Key contributions</h3>
          <ul class="mt-3 space-y-2">
            {project.details.highlights.map((item) => <li class="leading-7 muted">• {item}</li>)}
          </ul>

          <h3 class="project-dialog-section-title mt-8">Stack</h3>
          <div class="mt-3 flex flex-wrap gap-2">
            {project.details.stack.map((item) => <span class="chip">{item}</span>)}
          </div>
        </article>
      </dialog>
    ))
  }
</BaseLayout>

<script>
  const projectDialogs = Array.from(document.querySelectorAll('dialog[data-project-modal]'));
  const projectDialogMap = new Map(projectDialogs.map((modal) => [modal.getAttribute('data-project-modal'), modal]));
  const modalTriggers = document.querySelectorAll('[data-project-modal-trigger]');

  const buildProjectUrl = (slug: string | null) => {
    const url = new URL(window.location.href);
    if (slug) {
      url.searchParams.set('project', slug);
    } else {
      url.searchParams.delete('project');
    }

    return `${url.pathname}${url.search}${url.hash}`;
  };

  const openProjectDialog = (slug: string, options: { updateUrl: boolean } = { updateUrl: true }) => {
    const modal = projectDialogMap.get(slug);
    if (!(modal instanceof HTMLDialogElement)) return;

    projectDialogs.forEach((dialog) => {
      if (dialog !== modal && dialog instanceof HTMLDialogElement && dialog.open) {
        dialog.close();
      }
    });

    if (!modal.open) {
      modal.showModal();
    }

    if (options.updateUrl) {
      history.pushState({ project: slug }, '', buildProjectUrl(slug));
    }
  };

  const closeProjectDialog = (modal: Element | null, options: { updateUrl: boolean } = { updateUrl: true }) => {
    if (!(modal instanceof HTMLDialogElement) || !modal.open) return;

    modal.close();

    if (options.updateUrl) {
      history.pushState({ project: null }, '', buildProjectUrl(null));
    }
  };

  modalTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const slug = trigger.getAttribute('data-project-modal-trigger');
      if (!slug) return;
      openProjectDialog(slug);
    });
  });

  document.querySelectorAll('[data-project-modal-close]').forEach((button) => {
    button.addEventListener('click', () => {
      const modal = button.closest('dialog');
      closeProjectDialog(modal);
    });
  });

  projectDialogs.forEach((modal) => {
    modal.addEventListener('click', (event) => {
      if (event.target === modal) {
        closeProjectDialog(modal);
      }
    });
  });

  window.addEventListener('popstate', () => {
    const slug = new URL(window.location.href).searchParams.get('project');
    if (slug && projectDialogMap.has(slug)) {
      openProjectDialog(slug, { updateUrl: false });
      return;
    }

    projectDialogs.forEach((modal) => {
      if (modal instanceof HTMLDialogElement && modal.open) {
        closeProjectDialog(modal, { updateUrl: false });
      }
    });
  });

  const initialProjectSlug = new URL(window.location.href).searchParams.get('project');
  if (initialProjectSlug && projectDialogMap.has(initialProjectSlug)) {
    openProjectDialog(initialProjectSlug, { updateUrl: false });
  }
</script>

<style>
  .project-dialog {
    text-align: left;
  }

  .project-dialog-close {
    border: 0;
    background: transparent;
    color: var(--text);
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.2;
    padding: 0.2rem 0;
  }

  .project-dialog-close:hover,
  .project-dialog-close:focus-visible {
    color: var(--accent);
  }

  .project-dialog-section-title {
    color: var(--accent);
    font-size: 1rem;
    font-weight: 600;
  }
</style>

---
import ProjectCard from '@/components/ProjectCard.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { projects } from '@/features/projects/service';
---

<BaseLayout
  pageTitle="Projects"
  pageDescription="Project case studies and representative work by Bennet Vella."
>
  <SectionHeading
    eyebrow="Projects"
    title="Project and work snapshots"
    intro="The target Astro template organizes project data centrally. This version keeps that approach, but simplifies the content model to static case studies better suited to GitHub Pages and long-term editing."
  />
  <div class="grid gap-5 md:grid-cols-2">
    {projects.map((project) => <ProjectCard project={project} />)}
  </div>
</BaseLayout>

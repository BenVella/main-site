---
import SectionHeading from '@/components/SectionHeading.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { projects } from '@/features/projects/service';
import { withBase } from '@/utils/base-path';

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout
  pageTitle="Projects"
  pageDescription="Framed project snapshots from Exient with on-demand detail popups."
>
  <SectionHeading
    eyebrow="Projects"
    title="Framed project snapshots"
    intro="A lightweight gallery view with focused captions. Open any project for a deeper technical popup."
  />

  <div class="grid gap-5 md:grid-cols-2">
    {
      projects.map((project) => (
        <article class="section-card overflow-hidden rounded-[1.75rem] p-4">
          <img
            src={withBase(baseUrl, project.image.src)}
            alt={project.image.alt}
            loading="lazy"
            class="h-56 w-full rounded-2xl object-cover"
          />
          <div class="px-1 pb-2 pt-4">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] muted">{project.company}</p>
            <h3 class="mt-2 display-face text-2xl font-semibold">{project.title}</h3>
            <p class="mt-2 text-sm muted">{project.role} · {project.period}</p>
            <p class="mt-4 leading-7 muted">{project.caption}</p>
            <button
              type="button"
              class="button-secondary mt-5"
              data-project-modal-trigger={project.slug}
              aria-haspopup="dialog"
              aria-controls={`project-modal-${project.slug}`}
            >
              View deeper details
            </button>
            <a
              href={withBase(baseUrl, `projects/${project.slug}`)}
              class="mt-3 inline-flex text-sm font-semibold"
              style="color: var(--accent);"
            >
              Open standalone page
            </a>
          </div>
        </article>
      ))
    }
  </div>

  {
    projects.map((project) => (
      <dialog
        class="section-card w-[min(42rem,92vw)] rounded-[1.75rem] p-0 text-left backdrop:bg-slate-950/70"
        data-project-modal={project.slug}
        id={`project-modal-${project.slug}`}
      >
        <article class="p-6 md:p-8">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.16em] muted">{project.company}</p>
              <h2 class="mt-2 display-face text-3xl font-semibold">{project.title}</h2>
              <p class="mt-2 text-sm muted">{project.role} · {project.period}</p>
            </div>
            <button type="button" class="button-secondary" data-project-modal-close>
              Close
            </button>
          </div>
          <p class="mt-6 leading-7 muted">{project.details.summary}</p>

          <h3 class="mt-8 text-base font-semibold">Key contributions</h3>
          <ul class="mt-3 space-y-2">
            {project.details.highlights.map((item) => <li class="leading-7 muted">• {item}</li>)}
          </ul>

          <h3 class="mt-8 text-base font-semibold">Stack</h3>
          <div class="mt-3 flex flex-wrap gap-2">
            {project.details.stack.map((item) => <span class="chip">{item}</span>)}
          </div>
        </article>
      </dialog>
    ))
  }
</BaseLayout>

<script>
  const modalTriggers = document.querySelectorAll('[data-project-modal-trigger]');

  modalTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const slug = trigger.getAttribute('data-project-modal-trigger');
      if (!slug) return;
      const modal = document.querySelector(`[data-project-modal="${slug}"]`);
      if (modal instanceof HTMLDialogElement) {
        modal.showModal();
      }
    });
  });

  const closeButtons = document.querySelectorAll('[data-project-modal-close]');
  closeButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const modal = button.closest('dialog');
      if (modal instanceof HTMLDialogElement) {
        modal.close();
      }
    });
  });

  document.querySelectorAll('dialog[data-project-modal]').forEach((modal) => {
    modal.addEventListener('click', (event) => {
      if (event.target === modal && modal instanceof HTMLDialogElement) {
        modal.close();
      }
    });
  });
</script>

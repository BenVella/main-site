---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getProjectBySlug, projects } from '@/features/projects/service';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const project = getProjectBySlug(Astro.params.slug ?? '');

if (!project) {
  throw new Error('Project not found');
}
---

<BaseLayout pageTitle={project.title} pageDescription={project.summary}>
  <article class="section-card rounded-[2rem] p-8 md:p-10">
    <p class="eyebrow">{project.category}</p>
    <h1 class="display-face mt-4 text-4xl font-semibold md:text-6xl">
      {project.title}
    </h1>
    <p class="mt-4 text-sm font-semibold muted">{project.period}</p>
    <p class="mt-6 max-w-3xl text-lg leading-8 muted">{project.summary}</p>

    <div class="mt-8 flex flex-wrap gap-2">
      {
        project.tags.map((tag) => (
          <span class="chip">
            {tag}
          </span>
        ))
      }
    </div>

    <section class="mt-12 grid gap-8 lg:grid-cols-3">
      <div class="lg:col-span-1">
        <h2 class="display-face text-2xl font-semibold">Problem</h2>
        <p class="mt-4 leading-7 muted">{project.problem}</p>
      </div>
      <div class="lg:col-span-2">
        <h2 class="display-face text-2xl font-semibold">What I focused on</h2>
        <ul class="mt-4 space-y-3">
          {
            project.work.map((item) => (
              <li class="rounded-[1.25rem] px-5 py-4 leading-7" style="background: var(--surface-soft);">
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="display-face text-2xl font-semibold">Outcome</h2>
      <p class="mt-4 max-w-3xl leading-7 muted">{project.outcome}</p>
    </section>

    {
      project.links?.length ? (
        <section class="mt-10 flex flex-wrap gap-3">
          {project.links.map((link) => (
            <a
              href={link.href}
              class="button-secondary"
              target="_blank"
              rel="noreferrer"
            >
              {link.label}
            </a>
          ))}
        </section>
      ) : null
    }
  </article>
</BaseLayout>

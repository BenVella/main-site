---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getProjectBySlug, projects } from '@/features/projects/service';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const project = getProjectBySlug(Astro.params.slug ?? '');

if (!project) {
  throw new Error('Project not found');
}
---

<BaseLayout pageTitle={project.title} pageDescription={project.caption}>
  <article class="section-card overflow-hidden rounded-[2rem] p-5 md:p-8">
    <img
      src={project.image.src}
      alt={project.image.alt}
      class="h-64 w-full rounded-2xl object-cover md:h-[22rem]"
    />

    <p class="mt-6 text-xs font-semibold uppercase tracking-[0.16em] muted">{project.company}</p>
    <h1 class="display-face mt-3 text-4xl font-semibold md:text-6xl">{project.title}</h1>
    <p class="mt-3 text-sm font-semibold muted">{project.role} · {project.period}</p>
    <p class="mt-6 max-w-3xl text-lg leading-8 muted">{project.details.summary}</p>

    <section class="mt-10">
      <h2 class="display-face text-2xl font-semibold">Key contributions</h2>
      <ul class="mt-4 space-y-3">
        {
          project.details.highlights.map((item) => (
            <li class="rounded-[1.25rem] px-5 py-4 leading-7" style="background: var(--surface-soft);">
              {item}
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-10">
      <h2 class="display-face text-2xl font-semibold">Stack</h2>
      <div class="mt-4 flex flex-wrap gap-2">
        {project.details.stack.map((item) => <span class="chip">{item}</span>)}
      </div>
    </section>
  </article>
</BaseLayout>

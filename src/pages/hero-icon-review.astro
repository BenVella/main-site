---
import TechnologyBadge from '@/components/home/TechnologyBadge.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { Technology } from '@/features/home/content';

type ReviewedTechnology = Technology & {
  note: string;
  sourceLabel?: string;
  sourceUrl?: string;
  status: string;
};

const reviewedTechnologies: ReviewedTechnology[] = [
  {
    shortLabel: 'U',
    name: 'Unity',
    status: 'Review-only due trademark guidance',
    note:
      'Unity publishes official downloadables, but its current branding guidelines explicitly say not to use Unity logos simply to beautify materials and not to make them the most prominent element. I left the current fallback badge as the safer default until you decide you want a review-only candidate staged anyway.',
    sourceLabel: 'Unity trademark guidance',
    sourceUrl: 'https://unity.com/legal/branding-trademarks',
  },
  {
    shortLabel: 'C#',
    name: 'C#',
    iconFile: 'official/csharp.svg',
    status: 'Official candidate staged',
    note:
      'Pulled from the public dotnet/brand language-icons set. Microsoft\'s README for that folder says these images are provided for usage to represent the .NET languages and should not be altered or given extra adornment.',
    sourceLabel: 'dotnet/brand language icons',
    sourceUrl: 'https://github.com/dotnet/brand/tree/main/logo/language-icons',
  },
  {
    shortLabel: 'G',
    name: 'Git',
    iconFile: 'official/git.svg',
    status: 'Official candidate staged',
    note:
      'Using the official orange Git logomark SVG from git-scm.com. This is the strongest clean replacement for the current single-letter badge.',
    sourceLabel: 'Git logo downloads',
    sourceUrl: 'https://git-scm.com/community/logos',
  },
  {
    shortLabel: 'D',
    name: 'Docker',
    iconFile: 'official/docker.svg',
    status: 'Official candidate staged',
    note:
      'Using the official ocean-blue whale mark from Docker\'s downloadable logo kit. It reads well at badge size without needing the wordmark.',
    sourceLabel: 'Docker brand guidelines',
    sourceUrl: 'https://www.docker.com/company/newsroom/media-resources/',
  },
  {
    shortLabel: 'M',
    name: 'MuleSoft',
    status: 'Fallback only for now',
    note:
      'I did not find a clean, current official SVG kit from MuleSoft or Salesforce public brand pages during this pass. The letter badge stays in place until we pick a trusted alternative or locate an approved upstream asset.',
  },
  {
    shortLabel: '.N',
    name: '.NET',
    iconFile: 'official/dotnet.svg',
    status: 'Official candidate staged',
    note:
      'Using the public .NET brand repository logo SVG. This is the official platform mark and fits the existing badge shape cleanly.',
    sourceLabel: '.NET brand repo',
    sourceUrl: 'https://github.com/dotnet/brand',
  },
  {
    shortLabel: 'W',
    name: 'Windmill',
    iconFile: 'official/windmill.svg',
    status: 'Official candidate staged',
    note:
      'Using the primary SVG from Windmill\'s own brand guidelines. This is the same logo variant they recommend for light surfaces.',
    sourceLabel: 'Windmill brand guidelines',
    sourceUrl: 'https://www.windmill.dev/brand-guidelines/visual_identity/logo',
  },
];
---

<BaseLayout
  pageTitle="Hero Icon Review"
  pageDescription="Review page for official and fallback hero technology icons."
>
  <section class="mt-6">
    <SectionHeading
      eyebrow="Hero Review"
      title="Technology icon candidates"
      intro="Official SVGs are staged here where they were cleanly available. The current lettered badge remains the comparison fallback for every technology."
    />

    <div class="grid gap-5">
      {
        reviewedTechnologies.map((technology) => (
          <article class="section-card rounded-[1.5rem] p-6">
            <div class="flex flex-wrap gap-5">
              <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] muted">
                  Official candidate
                </p>
                {
                  technology.iconFile ? (
                    <TechnologyBadge technology={technology} />
                  ) : (
                    <div class="chip">Not staged</div>
                  )
                }
              </div>

              <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] muted">
                  Current fallback
                </p>
                <TechnologyBadge
                  technology={{ shortLabel: technology.shortLabel, name: technology.name }}
                />
              </div>
            </div>

            <p class="mt-5 text-sm font-semibold uppercase tracking-[0.18em] muted">
              {technology.status}
            </p>
            <p class="mt-2 max-w-3xl leading-7 muted">{technology.note}</p>
            {
              technology.sourceUrl ? (
                <p class="mt-3 text-sm">
                  <a href={technology.sourceUrl} target="_blank" rel="noreferrer">
                    {technology.sourceLabel}
                  </a>
                </p>
              ) : null
            }
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
